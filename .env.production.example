# ══════════════════════════════════════════════════════════════════════════════
# ReqAI – Production Environment Template
#
# Usage:
#   cp .env.production.example .env.production
#   # Fill in all values, then:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# This file is read by docker-compose.prod.yml via `env_file: .env.production`.
# It is also used to substitute ${VAR} references inside nginx/nginx.conf.
#
# Secret management recommendations:
#   • GitHub Actions: use Repository Secrets → env: VAR: ${{ secrets.VAR }}
#   • AWS: Secrets Manager → inject at task start
#   • Kubernetes: use k8s Secrets or Sealed Secrets
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Domain (used in Nginx config substitution) ────────────────────────────────
DOMAIN_NAME=reqai.example.com

# ── Application Version (injected by CI/CD) ───────────────────────────────────
APP_VERSION=1.0.0
BUILD_DATE=
GIT_COMMIT=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=reqai
POSTGRES_USER=reqai_prod
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ── JWT — generate with: openssl rand -hex 32 ────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_minimum_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_PROVIDER=OPENAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
FRONTEND_URL=https://reqai.example.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_FILE=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@reqai.example.com
SMTP_PASS=CHANGE_ME
FROM_EMAIL=noreply@reqai.example.com
