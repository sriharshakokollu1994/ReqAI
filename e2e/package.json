{
  "name": "reqai-e2e",
  "version": "1.0.0",
  "description": "ReqAI – End-to-End Tests (Playwright)",
  "private": true,
  "scripts": {
    "test":         "playwright test --config playwright.config.ts",
    "test:headed":  "playwright test --config playwright.config.ts --headed",
    "test:ui":      "playwright test --config playwright.config.ts --ui",
    "test:debug":   "playwright test --config playwright.config.ts --debug",
    "test:report":  "playwright show-report playwright-report",
    "codegen":      "playwright codegen http://localhost:5173"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node":      "^22.7.9",
    "dotenv":           "^16.4.5",
    "typescript":       "^5.6.3"
  }
}
