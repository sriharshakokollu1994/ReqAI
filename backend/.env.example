# ══════════════════════════════════════════════════════════════════════════════
# ReqAI Backend — Environment Configuration Template
#
# Usage:
#   cp .env.example .env          # development
#   cp .env.example .env.production  # fill in production secrets
#
# NEVER commit .env or .env.production to source control.
# All secrets must be injected at deploy time via CI/CD vault or secrets manager.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://reqai:reqai_password@localhost:5432/reqai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Format: redis://[:<password>@]<host>:<port>
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Minimum 32 characters. Use separate keys for access and refresh.
JWT_ACCESS_SECRET=change_me_access_secret_must_be_at_least_32_characters
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_at_least_32_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: OPENAI | AZURE_OPENAI | ANTHROPIC | WATSONX | CUSTOM
AI_PROVIDER=OPENAI

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Azure OpenAI (set these when AI_PROVIDER=AZURE_OPENAI)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com

# Anthropic Claude (set these when AI_PROVIDER=ANTHROPIC)
# ANTHROPIC_API_KEY=sk-ant-...

# IBM watsonx.ai (set these when AI_PROVIDER=WATSONX)
# WATSONX_API_KEY=
# WATSONX_PROJECT_ID=
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_MODEL=meta-llama/llama-3-1-70b-instruct

# ── Security ──────────────────────────────────────────────────────────────────
# bcrypt cost factor — 12 is the minimum recommendation for production
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────────────
# Must exactly match the origin that the browser sends
FRONTEND_URL=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: error | warn | info | http | debug
# Production recommendation: info
# Development recommendation: debug
LOG_LEVEL=debug
# Set LOG_TO_FILE=true to write rotating log files under ./logs/
LOG_TO_FILE=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# These are Express-level limits (Nginx adds an outer layer in production)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Email (optional — required for password reset flow) ───────────────────────
# Leave blank to disable; app runs fully without SMTP
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.com
# SMTP_PASS=your-smtp-password
# FROM_EMAIL=noreply@reqai.app

# ── S3 File Storage (optional — for requirement document uploads) ─────────────
# S3_BUCKET=reqai-uploads
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
