{
  "name": "reqai-backend",
  "version": "1.0.0",
  "description": "ReqAI – AI Requirement Analyzer — Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev":          "ts-node-dev --respawn --transpile-only --exit-child -r dotenv/config src/server.ts",
    "build":        "tsc --project tsconfig.json",
    "start":        "node dist/server.js",
    "lint":         "eslint 'src/**/*.ts' --fix",
    "lint:check":   "eslint 'src/**/*.ts'",
    "format":       "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck":    "tsc --noEmit",
    "db:migrate":   "node scripts/migrate.js",
    "db:seed":      "node scripts/seed.js",
    "db:seed:user": "node scripts/seed-user.js",
    "test":         "jest --config jest.config.ts",
    "test:watch":   "jest --config jest.config.ts --watch",
    "test:cov":     "jest --config jest.config.ts --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "axios":             "^1.7.7",
    "bcrypt":            "^5.1.1",
    "cookie-parser":     "^1.4.7",
    "bull":              "^4.16.3",
    "compression":       "^1.7.4",
    "cors":              "^2.8.5",
    "docx":              "^9.0.0",
    "dotenv":            "^16.4.5",
    "express":           "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet":            "^8.0.0",
    "js-yaml":           "^4.1.0",
    "jsonwebtoken":      "^9.0.2",
    "multer":            "^1.4.5-lts.1",
    "nodemailer":        "^6.9.15",
    "openai":            "^4.67.1",
    "pg":                "^8.13.1",
    "pdfkit":            "^0.15.0",
    "redis":             "^4.7.0",
    "swagger-ui-express": "^5.0.1",
    "uuid":              "^10.0.0",
    "winston":           "^3.15.0",
    "zod":               "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt":           "^5.0.2",
    "@types/cookie-parser":    "^1.4.8",
    "@types/bull":             "^4.10.4",
    "@types/compression":      "^1.7.5",
    "@types/cors":             "^2.8.17",
    "@types/express":          "^5.0.0",
    "@types/jest":             "^29.5.14",
    "@types/js-yaml":          "^4.0.9",
    "@types/jsonwebtoken":     "^9.0.7",
    "@types/multer":           "^1.4.12",
    "@types/node":             "^22.7.9",
    "@types/nodemailer":       "^6.4.16",
    "@types/pg":               "^8.11.10",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid":             "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser":        "^8.8.1",
    "eslint":                  "^9.13.0",
    "jest":                    "^29.7.0",
    "prettier":                "^3.3.3",
    "ts-jest":                 "^29.2.5",
    "ts-node-dev":             "^2.0.0",
    "typescript":              "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm":  ">=10.0.0"
  }
}
